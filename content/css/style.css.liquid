/* =============================================================================
   VARIABLES
   ============================================================================= */

:root {
  /* Colors */
  --color-primary: #4078c0;
  --color-text: #000;
  --color-bg: #fff;
  --color-border: #000;
  --color-row-odd: #f2f2f2;
  --color-row-even: #fcfcfc;

  /* Spacing */
  --space-xs: 0.5rem;
  --space-sm: 1rem;
  --space-md: 1.5rem;
  --space-lg: 2rem;

  /* Typography */
  --font-system: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  --font-header: Lato, var(--font-system);
  --font-size-header: min(48px, 4vw);

  /* Layout */
  --max-width: 1000px;
  --space-page-inline: 48px;
  --header-height: 200px;
  --border-width: 1px;
}

/* =============================================================================
   BASE
   ============================================================================= */

body {
  max-width: var(--max-width);
  margin-inline: auto;
  padding-inline: var(--space-sm);
  font-family: var(--font-system);
  color: var(--color-text);
}

/* Restore vertical spacing for content elements */
p, ul, ol, blockquote, pre, table {
  margin-block: 1rem;
}

h1, h2, h3, h4, h5, h6 {
  margin-block: 1.5rem;
}

footer {
  font-size: smaller;
  margin-top: 2lh;
  border-top: var(--border-width) solid var(--color-border);
}

.byline {
  font-size: smaller;
  margin-top: -1rem;
}

.upper {
  text-transform: uppercase;
}

.striped tbody tr:nth-child(odd) {
  background-color: var(--color-row-odd);
}

.striped tbody tr:nth-child(even) {
  background-color: var(--color-row-even);
}

.callsign {
  text-transform: uppercase;
}

/* =============================================================================
   HEADER
   ============================================================================= */

.site-header {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.site-logo {
  height: 48px;
  width: auto;
}

.site-header--home {
  flex-direction: column;
  text-align: center;
}

.site-header--home .site-logo {
  height: 200px;
}

/* =============================================================================
   NAVIGATION
   ============================================================================= */

.site-nav {
  display: flex;
  background-color: var(--color-primary);
}

.site-nav ul {
  list-style-type: none;
  margin: 0;
  padding: var(--space-xs) var(--space-sm);
}

.site-nav li {
  display: inline;
  border-left: var(--border-width) solid var(--color-bg);
  padding: var(--space-xs);
}

.site-nav li:first-child {
  border: none;
}

.site-nav a {
  color: var(--color-bg);
  text-decoration: none;
}

.site-nav li.active {
  font-weight: bold;
}

.nav-main {
  flex-grow: 1;
}

/* =============================================================================
   TABLES
   ============================================================================= */

td, th {
  vertical-align: top;
}

/* =============================================================================
   HOME LAYOUT
   ============================================================================= */

.home-layout {
  display: flex;
  gap: var(--space-lg);
}

.home-layout #main {
  flex: 1;
  min-width: 0;
}

.home-layout #announcements {
  flex: 0 0 250px;
  border-left: var(--border-width) solid var(--color-border);
  padding-left: var(--space-lg);
}

@media (max-width: 600px) {
  .home-layout {
    flex-direction: column;
  }

  .home-layout #announcements {
    flex-basis: auto;
    border-left: none;
    border-top: var(--border-width) solid var(--color-border);
    padding-left: 0;
    padding-top: var(--space-sm);
  }
}

