---
permalink: /css/style.css
layout: false
---

/* =============================================================================
   VARIABLES
   ============================================================================= */

{% render "css/variables.css" %}

:root {
  --color-bg: #fff;
  --color-row-odd: #f2f2f2;
  --color-row-even: #fcfcfc;

  --space-xs: 0.5rem;
  --space-md: 1.5rem;
  --space-lg: 2rem;

  --font-header: Lato, var(--font-system);
  --font-size-header: min(48px, 4vw);

  --space-page-inline: 48px;
  --header-height: 200px;
}

/* =============================================================================
   BASE
   ============================================================================= */

body {
  max-width: var(--max-width);
  margin-inline: auto;
  padding-inline: var(--space-sm);
  font-family: var(--font-system);
  color: var(--color-text);
}

/* Restore vertical spacing for content elements */
p, ul, ol, blockquote, pre, table {
  margin-block: 1rem;
}

h1, h2, h3, h4, h5, h6 {
  margin-block: 1.5rem;
}

footer {
  font-size: smaller;
  margin-top: 2lh;
  border-top: var(--border-width) solid var(--color-border);
}

.byline {
  font-size: smaller;
  margin-top: -1rem;
}

.upper {
  text-transform: uppercase;
}

.striped tbody tr:nth-child(odd),
.handbook tbody tr:nth-child(odd) {
  background-color: var(--color-row-odd);
}

.striped tbody tr:nth-child(even),
.handbook tbody tr:nth-child(even) {
  background-color: var(--color-row-even);
}

.callsign {
  text-transform: uppercase;
  position: relative;
}

.callsign-popup {
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%);
  margin-bottom: 8px;
  width: max-content;
  background: var(--color-bg);
  border: var(--border-width) solid var(--color-border);
  border-radius: 4px;
  padding: var(--space-xs) var(--space-sm);
  white-space: nowrap;
  font-size: 0.85rem;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  text-transform: none;
}

.callsign-popup::after {
  content: "";
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  border: 6px solid transparent;
  border-top-color: var(--color-border);
}

.callsign-popup dl {
  display: grid;
  grid-template-columns: auto auto;
  gap: 0 0.5em;
  margin: 0;
}

.callsign-popup dt {
  font-weight: bold;
}

.callsign-popup dt::after {
  content: ":";
}

.callsign-popup dd {
  margin-left: 0;
}

.callsign-popup .popup-call {
  font-weight: bold;
  text-transform: uppercase;
  margin-bottom: 0.25em;
}

/* =============================================================================
   HEADER
   ============================================================================= */

.site-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-sm);
}

.site-logo {
  height: 48px;
  width: auto;
}

.site-header--home {
  flex-direction: column;
  text-align: center;
  padding-block: var(--space-lg);
}

.site-header--home .site-logo {
  height: 200px;
}

/* =============================================================================
   NAVIGATION
   ============================================================================= */

.site-nav {
  display: flex;
  background-color: var(--color-primary);
}

.site-nav ul {
  list-style-type: none;
  margin: 0;
  padding: var(--space-xs) var(--space-sm);
}

.site-nav li {
  display: inline;
  border-left: var(--border-width) solid var(--color-bg);
  padding: var(--space-xs);
}

.site-nav li:first-child {
  border: none;
}

.site-nav a {
  color: var(--color-bg);
  text-decoration: none;
}

.site-nav li.active {
  font-weight: bold;
}

.nav-main {
  flex-grow: 1;
}

.nav-toggle {
  display: none;
}

.nav-toggle-bar {
  display: block;
  width: 25px;
  height: 3px;
  background: white;
  border-radius: 2px;
}

@media (max-width: 768px) {
  .site-nav {
    flex-wrap: wrap;
  }

  .nav-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.75rem 1rem;
  }

  .nav-main {
    display: none;
    width: 100%;
  }

  .site-nav.open .nav-main {
    display: block;
  }

  .site-nav.open li {
    display: block;
    border-left: none;
    border-bottom: var(--border-width) solid rgba(255, 255, 255, 0.2);
  }

  .site-nav.open li:last-child {
    border-bottom: none;
  }
}

/* =============================================================================
   PRIORITY BANNER
   ============================================================================= */

.priority-banner {
  border: var(--border-width) solid var(--color-border);
  background-color: #ffeb3b;
  padding: var(--space-xs) var(--space-sm);
  margin-top: var(--space-sm);
}

.priority-banner p:first-of-type {
  margin-top: var(--space-xs);
}

.priority-banner p:last-child {
  margin-bottom: var(--space-xs);
}

/* =============================================================================
   TABLES
   ============================================================================= */

td, th {
  vertical-align: top;
  text-align: left;
}

th {
  background-color: #c0c0c0;
}

/* =============================================================================
   HOME LAYOUT
   ============================================================================= */

.home-layout {
  display: flex;
  gap: var(--space-lg);
}

.home-layout #main {
  flex: 1;
  min-width: 0;
}

.home-layout #announcements {
  flex: 0 0 250px;
  border-left: var(--border-width) solid var(--color-border);
  padding-left: var(--space-lg);
}

@media (max-width: 768px) {
  .home-layout {
    flex-direction: column;
  }

  .home-layout #announcements {
    flex-basis: auto;
    border-left: none;
    border-top: var(--border-width) solid var(--color-border);
    padding-left: 0;
    padding-top: var(--space-sm);
  }
}

/* =============================================================================
   PAGINATION
   ============================================================================= */

.pagination-nav {
  display: flex;
  justify-content: space-between;
  margin-top: var(--space-lg);
  padding-top: var(--space-sm);
  border-top: var(--border-width) solid var(--color-border);
}

.pagination-nav .pagination-older {
  margin-left: auto;
}

/* =============================================================================
   SILENT KEY
   ============================================================================= */

.sk-entry {
  border-top: var(--border-width) solid var(--color-border);
  padding-block: var(--space-md);
  overflow: hidden;
}

.sk-entry h3 {
  margin-top: 0;
}

.sk-photo {
  float: left;
  max-width: 150px;
  height: auto;
  margin-right: var(--space-md);
  margin-bottom: var(--space-xs);
  border-radius: 6px;
  box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
}

.sk-military h3::after {
  content: "\1F1FA\1F1F8";
  margin-left: var(--space-xs);
}

/* =============================================================================
   PRINTING
   ============================================================================= */

@media print {
  .noprint {
    display: none;
  }

  img {
    break-inside: avoid;
    page-break-inside: avoid;
  }
}
