---
layout: base.liquid
---

<header class="site-header site-header--home">
  <img src="/assets/caara-logo-medium.png" alt="CAARA logo" class="site-logo">
  <h1>Cape Ann Amateur Radio Association</h1>
</header>

<div class="home-layout">
  <section id="main">
  {{ content }}
  </section>

  <section id="announcements">
  <h2>Announcements</h2>
  {% assign sorted_posts = collections.post | reverse %}
  <ul>
  {% for post in sorted_posts limit: 5 %}
    <li>
      <p><a href="{{ post.url }}">{{ post.data.title }}</a></p>
      <p class="byline">{{ post.date | date: "%Y-%m-%d" }}{% if post.data.author %} by {{ post.data.author | formatAuthor }}{% endif %}</p>
    </li>
  {% endfor %}
  </ul>

  <p><a href="/announcements">more...</a></p>
  </section>
</div>
