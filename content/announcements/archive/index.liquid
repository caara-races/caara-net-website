---
title: Announcements Archive
weight: 20
override:tags: []
---

{% assign posts = collections.post | reverse %}
{% assign current_year = "" %}
{% for post in posts %}
  {% assign post_year = post.date | date: "%Y" %}
  {% if post_year != current_year %}
    {% if current_year != "" %}</ul>{% endif %}
    <h2>{{ post_year }}</h2>
    <ul>
    {% assign current_year = post_year %}
  {% endif %}
  <li>{{ post.date | date: "%Y-%m-%d" }} &mdash; <a href="{{ post.url }}">{{ post.data.title }}</a></li>
{% endfor %}
{% if current_year != "" %}</ul>{% endif %}
