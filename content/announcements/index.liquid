---
title: Announcements
weight: 20
override:tags: page
pagination:
  data: collections.post
  size: 5
  reverse: true
---

<p>See the <a href="/announcements/archive">archive</a> for a concise summary of all available announcements.</p>

{% for post in pagination.items %}
<h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
<p class="byline">{{ post.date | date: "%Y-%m-%d" }}{% if post.data.author %} by {{ post.data.author | formatAuthor }}{% endif %}</p>
{% if forloop.first and pagination.pageNumber == 0 %}
{{ post.templateContent }}
{% elsif post.templateContent contains "<!-- more -->" %}
{{ post.templateContent | split: "<!-- more -->" | first }}

<p><a href="{{ post.url }}">Continue reading...</a></p>
{% else %}
{{ post.templateContent }}
{% endif %}
{% endfor %}

{% if pagination.href.previous or pagination.href.next %}
<nav class="pagination-nav" aria-label="Announcements pagination">
  {% if pagination.href.previous %}
  <a class="pagination-newer" href="{{ pagination.href.previous }}">&laquo; Newer</a>
  {% endif %}
  {% if pagination.href.next %}
  <a class="pagination-older" href="{{ pagination.href.next }}">Older &raquo;</a>
  {% endif %}
</nav>
{% endif %}
