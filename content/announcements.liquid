---
title: Announcements
weight: 20
tags: page
---

{% assign sorted_posts = collections.post | reverse %}
{% for post in sorted_posts %}
<h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
<p class="byline">{{ post.date | date: "%Y-%m-%d" }}{% if post.data.author %} by {{ post.data.author | formatAuthor }}{% endif %}</p>
{% if forloop.first %}
{{ post.templateContent }}
{% elsif post.templateContent contains "<!-- more -->" %}
{{ post.templateContent | split: "<!-- more -->" | first }}

<p><a href="{{ post.url }}">Continue reading...</a></p>
{% else %}
{{ post.templateContent }}
{% endif %}
{% endfor %}
